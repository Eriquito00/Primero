{
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "lib": ["DOM", "ESNext"],
        "types": [],
        "sourceMap": false,
        "noEmitOnError": true,
        "noImplicitAny": true,
        "strict": true,
        "allowSyntheticDefaultImports": true,
        "outDir": "./public/js",
        "rootDir": "./src/"
    },
    "include": ["src/**/*"],
    "exclude": ["../node_modules", "node_modules"]
}